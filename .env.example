# Square (get from developer.squareup.com → your app → Credentials)
SQUARE_ACCESS_TOKEN=your_square_access_token_here
SQUARE_LOCATION_ID=your_square_location_id_here
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key_here
SQUARE_ENVIRONMENT=sandbox  # change to "production" when ready to go live

# Resend (get from resend.com → API Keys)
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=invoices@yourdomain.com  # must be a verified domain in Resend

# Supabase (get from supabase.com → project → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# Your app's public URL (used for Square redirect after payment)
APP_URL=https://your-netlify-site.netlify.app
